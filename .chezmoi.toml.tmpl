# Customize configuration when running `chezmoi init`
# This template will trigger prpompts to fill in machine specific
# data, such as the email or name to use for instance

{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

# Prompt for the user email
{{ $email := promptString "Git email address for the author/committer" -}}

# Store email and osid so that they can be used later
[data]
  email = {{ $email | quote }}
  osid = {{ $osid | quote }}

# Install Bitwarden CLI
[hooks.read-source-state.pre]
  command = ".local/share/chezmoi/.install-bitwarden-CLI.sh"
