{{ if eq .osid "linux-linuxmint" -}}
#!/bin/bash
echo "#########################################################################"
echo "#####                 Install generic utility tools                 #####"
echo "#########################################################################"
echo "*************************************************************************"
echo "*****                     Install Standard Notes                    *****"
echo "*************************************************************************"
# Standard Notes
if flatpak list --app | grep -q "Standard Notes"
then
  echo "Standard Notes already installed, skipping installation"
else
  flatpak install -y org.standardnotes.standardnotes
fi

echo "*************************************************************************"
echo "*****                       Install Bitwarden                       *****"
echo "*************************************************************************"
# Bitwarden
if flatpak list --app | grep -q "Bitwarden"
then
  echo "Bitwarden already installed, skipping installation"
else
  flatpak install -y com.bitwarden.desktop
fi

echo "*************************************************************************"
echo "*****                        Install Espanso                        *****"
echo "*************************************************************************"
# Espanso text expander
if ! command -v espanso >/dev/null 2>&1
then
  # Create the $HOME/opt destination folder
  mkdir -p ~/opt
  # Download the AppImage inside it
  wget -O ~/opt/Espanso.AppImage 'https://github.com/espanso/espanso/releases/download/v2.2.1/Espanso-X11.AppImage'
  # Make it executable
  chmod u+x ~/opt/Espanso.AppImage
  # Create the "espanso" command alias
  sudo ~/opt/Espanso.AppImage env-path register
  # Register espanso as a systemd service (required only once)
  espanso service register
  # Start espanso
  espanso start
else
  echo "espanso already installed, skipping installation"
fi

{{ else if eq .osid "linux-arch" -}}
#!/bin/bash
echo "#########################################################################"
echo "#####                 Install generic utility tools                 #####"
echo "#########################################################################"

echo "*************************************************************************"
echo "*****                     Install Standard Notes                    *****"
echo "*************************************************************************"
yay -S --noconfirm --needed standardnotes-desktop

echo "*************************************************************************"
echo "*****                       Install Bitwarden                       *****"
echo "*************************************************************************"
yay -S --noconfirm --needed bitwarden

echo "*************************************************************************"
echo "*****                    Install Bitwarden CLI                      *****"
echo "*************************************************************************"
if ! command -v bw >/dev/null 2>&1
then
  BW_VERSION=$(curl -s "https://api.github.com/repos/bitwarden/clients/releases" | grep -o '"tag_name": "cli-v[^"]*"' | head -1 | grep -o '[0-9][^"]*')
  echo "Downloading Bitwarden CLI v$BW_VERSION"
  mkdir -p ~/.bin
  wget -O /tmp/bw-linux.zip "https://github.com/bitwarden/clients/releases/download/cli-v${BW_VERSION}/bw-linux-${BW_VERSION}.zip"
  unzip -o /tmp/bw-linux.zip -d /tmp/bw-extract
  mv /tmp/bw-extract/bw ~/.bin/bw
  chmod +x ~/.bin/bw
  rm -rf /tmp/bw-linux.zip /tmp/bw-extract
  echo "Bitwarden CLI v$BW_VERSION installed to ~/.bin/bw"
else
  echo "Bitwarden CLI already installed, skipping"
fi

echo "*************************************************************************"
echo "*****                        Install Espanso                        *****"
echo "*************************************************************************"
if ! command -v espanso >/dev/null 2>&1
then
  yay -S --noconfirm --needed espanso-wayland
  espanso service register
  espanso start
else
  echo "espanso already installed, skipping installation"
fi

echo "*************************************************************************"
echo "*****                     Install Scrollshot                        *****"
echo "*************************************************************************"
yay -S --noconfirm --needed scrollshot-bin

{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/sh
brew install --cask espanso
brew install --cask bitwarden
brew install --cask standard-notes
{{ end -}}
